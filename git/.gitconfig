[include]
	path = ~/.config/git/gitconfig_private
[core]
	autocrlf = input
	editor = "nvim --clean"
	excludesfile = ~/.config/git/.gitignore_global
	pager = "less -FX"
	whitespace=warn,indent-with-non-tab,trailing-space,cr-at-eol
[alias]
	a = add --verbose
	an = add --dry-run --verbose
	ai = add --patch
	app = apply --verbose
	br = branch --verbose --color
	ci = commit
	cl = clone
	cln = clone
	co = checkout
	com = checkout master
	dt = difftool
	dc = difftool --cached
	dw = difftool --ignore-all-space
	fu = fetch upstream
	chkig = check-ignore --verbose
	# show files ignored by git
	ign = ls-files -o -i --exclude-standard
	lg = log --graph --date=format:'%Y-%m-%d %H:%M' --format=format:'%C(auto)%h %d%Creset%Cgreen%ad%Creset %aN <%aE>%n%Cblue%s%Creset%+b'
	lgd = log -p
	lgm = log --graph --author='Sarah H. McGrath' --date=format:'%Y-%m-%d %H:%M' --format=format:'%C(auto)%h %d%Creset%Cgreen%ad%Creset %aN <%aE>%n%Cblue%s%Creset%+b'
	lgp = log --date=format:'%Y-%m-%d %H:%M' --pretty=fuller
	ls = ls-files | less
	mt = mergetool
	rem = remote --verbose
	rmc = rm -r --cached
	rs = restore --staged
	st = status --short --branch --show-stash --verbose
[color]
	ui = auto
	ui = true
[color "branch"]
	current = yellow reverse
	local = yellow
	remote = green
[color "diff"]
	meta = yellow bold
	frag = magenta bold
	old = red bold
	new = green bold
	whitespace = red reverse
[color "status"]
	added = yellow
	changed = green
	untracked = cyan
[diff]
	tool = nvimdiff
[difftool]
	prompt = false
[merge]
	tool = nvimdiff2
	; bug in neovim with nvimdiff2, see issues below:
	; https://github.com/tpope/vim-fugitive/issues/2444
	; https://github.com/neovim/neovim/issues/22696
	; https://github.com/neovim/neovim/issues/35513
	; gist on mergetools https://gist.github.com/karenyyng/f19ff75c60f18b4b8149
[mergetool]
	prompt = false
[mergetool "diffview"]
    cmd = nvim -n -c "DiffviewOpen" "$MERGED"
[mergetool "fugitive"]
	cmd = nvim -f -c "Gvdiffsplit!" "$MERGED"
[init]
	defaultBranch = main
[pager]
	diff = "less -FX"
[sendemail]
    sendmailCmd = /usr/bin/msmtp
	confirm = always
	validate = true
[status]
	showUntrackedFiles = normal
