#!/usr/bin/env bash
# lf previewer script
#
# lf's previewer interface:
#   $1  file path
#   $2  width       (columns of the preview pane)
#   $3  height      (lines of the preview pane)
#   $4  x position  (horizontal offset of the preview pane)
#   $5  y position  (vertical offset of the preview pane)
#   $6  mode        ("preview" or "preload" when the preload option is enabled)
#
# Exit codes:
#   0           Output is cached by lf. The previewer will not be called again
#               for this file until lf decides the cache is stale.
#   non-zero    Output is not cached. The previewer is called again every time
#               the file is selected.
#

set -o noclobber -o noglob -o nounset -o pipefail
IFS=$'\n'

FILE_PATH="${1}"           # Full path of the highlighted file
PV_WIDTH="${2:-80}"        # Width of the preview pane (columns); default 80
PV_HEIGHT="${3:-40}"       # Height of the preview pane (lines);  default 40
# $4 x position, $5 y position, $6 mode — unused here

FILE_EXTENSION="${FILE_PATH##*.}"
FILE_EXTENSION_LOWER="$(printf "%s" "${FILE_EXTENSION}" | tr '[:upper:]' '[:lower:]')"

## Settings
SQLITE_TABLE_LIMIT=20   # top N tables shown; 0 = only show sqlite_master
SQLITE_ROW_LIMIT=5      # first + last N-1 rows per table; 0 = no limit

# unset the SIXEL variable to disable image preview
SIXEL=true

# Try multiple commands until one succeeds
try() {
    "$@" 2>/dev/null && return 0
    return 1
}

# ---------------------------------------------------------------------------
# handle_extension — file-extension-based dispatch
# ---------------------------------------------------------------------------
handle_extension() {
	case "${FILE_EXTENSION_LOWER}" in

		## Archives
		a|ace|alz|arc|arj|br|bz|bz2|bz3|cbr|cb7|cbt|cbz|cab|cpio|\
		deb|gz|jar|lha|lzh|lz|lz4|lzma|lzo|rpm|rz|t7z|tar|tbz|tbz2|tgz|\
		tlz|txz|tZ|tzo|war|xpi|xz|Z|sz|tzst|zst|zip)
			try ouch list -t -- "$FILE_PATH" ||
			try atool --list -- "$FILE_PATH" ||
			try bsdtar --list --file "$FILE_PATH"
			exit $?
			;;

		rar)
			## Avoid password prompt by providing empty password
			try unrar lt -p- -- "${FILE_PATH}"
			exit $?
			;;

		7z)
			## Avoid password prompt by providing empty password
			try 7zz l -p -- "${FILE_PATH}"
			exit $?
			;;

		## PDF — text conversion
		pdf)
			try mutool draw -F txt -i -- "${FILE_PATH}" 1-10 \
				| fmt -w "${PV_WIDTH}" ||
			try exiftool "${FILE_PATH}"
			exit $?
			;;

		torrent)
			try transmission-show -- "${FILE_PATH}"
			exit $?
			;;
		md|mdown|markdown)
			try glow -- "${FILE_PATH}"
			exit $?
			;;

		## OpenDocument
		odt|sxw)
			try odt2txt "${FILE_PATH}" ||
			try pandoc -s -t markdown -- "${FILE_PATH}"
			exit $?
			;;

		ods|odp)
			try odt2txt "${FILE_PATH}"
			exit $?
			;;

		xlsx)
			try xlsx2csv -- "${FILE_PATH}"
			exit $?
			;;

		htm|html|xhtml)
			try w3m -dump "${FILE_PATH}" ||
			try pandoc -s -t markdown -- "${FILE_PATH}"
			exit $?
			;;

		json)
			try jq --color-output . "${FILE_PATH}" ||
			try python -m json.tool -- "${FILE_PATH}"
			exit $?
			;;

		## Jupyter Notebooks
		ipynb)
			try jupyter nbconvert --to markdown "${FILE_PATH}" --stdout \
				| bat --color=always --strip-ansi=always --style=plain \
					  --language=markdown ||
			try jupyter nbconvert --to markdown "${FILE_PATH}" --stdout ||
			try jq --color-output . "${FILE_PATH}" ||
			try python -m json.tool -- "${FILE_PATH}"
			exit $?
			;;

		## Audio formats not reliably detected by file(1)
		dff|dsf|wv|wvc)
			try mediainfo "${FILE_PATH}" ||
			try exiftool "${FILE_PATH}"
			exist $?
			;;
	esac
}

# ---------------------------------------------------------------------------
# handle_mime — MIME-type-based dispatch
# ---------------------------------------------------------------------------
handle_mime() {
    local MIMETYPE="${1}"

    case "${MIMETYPE}" in

        ## RTF and DOC
        text/rtf|*msword)
            try catdoc -- "${FILE_PATH}"
			exit $?
            ;;

        ## DOCX, ePub, FB2
        *wordprocessingml.document|*/epub+zip|*/x-fictionbook+xml)
            try pandoc -s -t markdown -- "${FILE_PATH}"
            exit $?
            ;;

        ## E-mail
        message/rfc822)
            try mu view -- "${FILE_PATH}"
            exit $?
            ;;

        ## xls
        *ms-excel)
            try xls2csv -- "${FILE_PATH}"
            exit $?
            ;;

        ## SQLite
        *sqlite3)
            SQLITE_TABLES="$(sqlite3 "file:${FILE_PATH}?mode=ro" '.tables')" \
                || exit 1
            [ -z "${SQLITE_TABLES}" ] && { echo "Empty SQLite database." && exit 0; }

            sqlite_show_query() {
                sqlite-utils query "${FILE_PATH}" "${1}" --table --fmt fancy_grid \
                    || sqlite3 "file:${FILE_PATH}?mode=ro" "${1}" -header -column
            }

            SQLITE_ROWCOUNT_QUERY="$(
                sqlite3 "file:${FILE_PATH}?mode=ro" -noheader \
                    'SELECT group_concat(
                        "SELECT """ || name || """ AS tblname,
                        count(*) AS rowcount
                        FROM " || name,
                        " UNION ALL "
                    )
                    FROM sqlite_master
                    WHERE type="table" AND name NOT LIKE "sqlite_%";'
            )"
            sqlite_show_query \
                "SELECT tblname AS 'table', rowcount AS 'count',
                    (
                        SELECT '(' || group_concat(name, ', ') || ')'
                        FROM pragma_table_info(tblname)
                    ) AS 'columns',
                    (
                        SELECT '(' || group_concat(
                            upper(type) || (
                                CASE WHEN pk > 0 THEN ' PRIMARY KEY' ELSE '' END
                            ),
                            ', '
                        ) || ')'
                        FROM pragma_table_info(tblname)
                    ) AS 'types'
                FROM (${SQLITE_ROWCOUNT_QUERY});"

            if [ "${SQLITE_TABLE_LIMIT}" -gt 0 ] \
                && [ "${SQLITE_ROW_LIMIT}" -ge 0 ]; then

                echo && printf '>%.0s' $(seq "${PV_WIDTH}") && echo

                sqlite3 "file:${FILE_PATH}?mode=ro" -noheader \
                    "SELECT name FROM sqlite_master
                     WHERE type='table' AND name NOT LIKE 'sqlite_%'
                     LIMIT ${SQLITE_TABLE_LIMIT};" |
                while read -r SQLITE_TABLE; do
                    SQLITE_ROWCOUNT="$(
                        sqlite3 "file:${FILE_PATH}?mode=ro" -noheader \
                            "SELECT count(*) FROM ${SQLITE_TABLE}"
                    )"
                    echo

                    if [ "${SQLITE_ROW_LIMIT}" -gt 0 ] \
                        && [ "${SQLITE_ROW_LIMIT}" -lt "${SQLITE_ROWCOUNT}" ]; then

                        echo "${SQLITE_TABLE} [${SQLITE_ROW_LIMIT} of ${SQLITE_ROWCOUNT}]:"

                        SQLITE_ELLIPSIS_QUERY="$(
                            sqlite3 "file:${FILE_PATH}?mode=ro" -noheader \
                                "SELECT 'SELECT ' || group_concat(
                                    '''...''', ', '
                                )
                                FROM pragma_table_info('${SQLITE_TABLE}');"
                        )"

                        sqlite_show_query \
                            "SELECT * FROM (
                                SELECT * FROM ${SQLITE_TABLE} LIMIT 1
                            )
                            UNION ALL ${SQLITE_ELLIPSIS_QUERY} UNION ALL
                            SELECT * FROM (
                                SELECT * FROM ${SQLITE_TABLE}
                                LIMIT (${SQLITE_ROW_LIMIT} - 1)
                                OFFSET (
                                    ${SQLITE_ROWCOUNT}
                                    - (${SQLITE_ROW_LIMIT} - 1)
                                )
                            );"
                    else
                        echo "${SQLITE_TABLE} [${SQLITE_ROWCOUNT}]:"
                        sqlite_show_query "SELECT * FROM ${SQLITE_TABLE};"
                    fi
                done
            fi

            exit 0
            ;;

        ## Plain text and XML — bat then cat
        text/*|*/xml)
			try bat --strip-ansi=always --color=always --style=plain -- "$FILE_PATH" ||
			cat -v "$FILE_PATH"
			exit $?
			;;

        ## DjVu — text conversion
        image/vnd.djvu)
            try djvutxt "${FILE_PATH}" | fmt -w "${PV_WIDTH}" ||
            try exiftool "${FILE_PATH}"
            exit $?
            ;;

        ## The previewer shows metadata by default, but will render the image if $SIXEL is true.
		image/*)
			if [ "${SIXEL:-}" = true ] && [ -z "${TMUX-}" ]; then
				try chafa -f sixel -s "$PV_WIDTH"x"$PV_HEIGHT" --animate off --polite on "${FILE_PATH}"
				exit $?
			fi
			try exiftool "${FILE_PATH}"
			exit $?
			;;

        ## Video and audio
        video/*|audio/*)
            try mediainfo "${FILE_PATH}" ||
            try exiftool "${FILE_PATH}"
            exit $?
            ;;

        ## ELF binaries and shared objects
        application/x-executable|application/x-pie-executable|application/x-sharedlib)
            try readelf -WCa "${FILE_PATH}"
            exit $?
            ;;
		application/pdf)
			try mutool draw -F txt -i -- "${FILE_PATH}" 1-10 \
				| fmt -w "${PV_WIDTH}" ||
			try exiftool "${FILE_PATH}"
			exit $?
			;;

	esac
}

handle_fallback() {
    echo '----- File Type Classification -----'
    file --dereference --brief -- "${FILE_PATH}" && exit 0
}

# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------
MIMETYPE="$(file --dereference --brief --mime-type -- "${FILE_PATH}")"

handle_extension
handle_mime "${MIMETYPE}"
handle_fallback

exit 1

# text types from text previewer example
# bash|c|cc|cfg|cjs|conf|cpp|css|csv|cxx|env|go|h|hh|hpp|html|htm|ini|java|js|json|ksh|kt|\
# log|md|mjs|patch|php|pl|prop|properties|py|rb|rs|rst|service|sh|sql|swift|timer|toml|\
# ts|tsv|txt|xhtml|xml|yaml|yml|zsh)
