{
	"lia": {
		"prefix": ["lia"],
		"body": [
			"<li><a href=\"${1:$CLIPBOARD}\"${4:data-tags=\"${3:tags}\"}>${2:$TM_SELECTED_TEXT}</a></li>$0"
		],
		"description": ""
	},
	"p": {
		"prefix": ["p"],
		"body": [
			"<p>${1:$TM_SELECTED_TEXT}</p>"
		],
		"description": "paragraph"
	},
	"h": {
		"prefix": ["h"],
		"body": [
			"<h${1:HeadingSize}>${2:${TM_SELECTED_TEXT:Heading}}</h${1}>"
		],
		"description": "Heading"
	},
	"hid": {
		"prefix": ["hid"],
		"body": [
			"<h${1:HeadingSize} id=\"${2:heading-id}\">${3:${TM_SELECTED_TEXT:Heading}}</h${1}>"
		],
		"description": "Heading with id"
	},
	"title": {
		"prefix": ["title"],
		"body": [
			"<title>${1:$TM_SELECTED_TEXT}</title>"
		],
		"description": "Title tag"
	},
	"img": {
		"prefix": ["img"],
		"body": [
			"<img src=\"${1:$TM_SELECTED_TEXT}\" alt=\"${2:Image description}\" />"
		],
		"description": "Image with alt text"
	},
	"fig": {
		"prefix": ["fig"],
		"body": [
			"<figure>${1:$TM_SELECTED_TEXT}</figure>"
		],
		"description": "figure"
	},
	"figcap": {
		"prefix": ["figcap"],
		"body": [
			"<figurecaption>${1:$TM_SELECTED_TEXT}</figurecaption>"
		],
		"description": "figure caption"
	},
	"ul": {
		"prefix": ["ul"],
		"body": [
			"<ul class=\"twoColumnList\">${1:$TM_SELECTED_TEXT}</ul>"
		],
		"description": "Unordered list"
	},
	"ol": {
		"prefix": ["ol"],
		"body": [
			"<ol>${1:$TM_SELECTED_TEXT}</ol>"
		],
		"description": "Ordered list"
	},
	"a": {
		"prefix": ["a"],
		"body": [
			"<a href=\"${1:URL}\">${2:$TM_SELECTED_TEXT}</a>"
		],
		"description": "insert a link anchor link"
	},
	"li": {
		"prefix": ["li"],
		"body": [
			"<li>${1:$TM_SELECTED_TEXT}</li>"
		],
		"description": "List item"
	},
	"header": {
		"prefix": ["header"],
		"body": [
			"<header id=\"${1:header-main}\" class=\"${2:header}\">${3:$TM_SELECTED_TEXT}</header>"
		],
		"description": "header tag"
	},
	"nav": {
		"prefix": ["nav"],
		"body": [
			"<nav>${1:$TM_SELECTED_TEXT}</nav>"
		],
		"description": "navigation tag"
	},
	"footer": {
		"prefix": ["footer"],
		"body": [
			"<footer id=\"${1:footer-main}\" class=\"${2:footer}\">${3:$TM_SELECTED_TEXT}</footer>"
		],
		"description": "footer tag"
	},
	"details": {
		"prefix": ["details"],
		"body": [
			"<details>",
			"\t<summary>${1:$TM_SELECTED_TEXT}</summary>",
			"</details>"
		],
		"description": "details element"
	},
	"meta": {
		"prefix": ["meta"],
		"body": [
			"<meta name=\"$1\" content=\"$2\">"
		],
		"description": "meta tag"
	},
	"script block": {
		"prefix": ["scriptblock"],
		"body": [
			"<script type=\"text/javascript\">",
			"\t${1:$TM_SELECTED_TEXT}",
			"</script>"
		],
		"description": "script block"
	},
	"script tag": {
		"prefix": ["script"],
		"body": [
			"<script type=\"text/javascript\" src=\"${1:./script/main.js}\"></script>",
		],
		"description": "javascript link - external or other file"
	},
	"style": {
		"prefix": ["style"],
		"body": [
			"<style type=\"text/css\">",
			"\t${1:$TM_SELECTED_TEXT}",
			"</style>"
		],
		"description": "style block"
	},
	"stylesheet link": {
		"prefix": ["stylesheetlink"],
		"body": [
			"<link rel=\"stylesheet\" href=\"${1:/css/main.css}\">"
		],
		"description": "stylesheet link"
	},
	"div": {
		"prefix": ["div"],
		"body": [
			"<div id=\"${1:id}\" class=\"${2:class}\">${3:$TM_SELECTED_TEXT}</div>"
		],
		"description": "div"
	},
	"toplink": {
		"prefix": ["toplink"],
		"body": [
			"<a href=\"#top\">${1:Back to Top}</a>"
		],
		"description": "back to top link"
	},
	"idclass": {
		"prefix": ["idclass"],
		"body": [
			"id=\"${1:id}\" class=\"${2:class}\""
		],
		"description": "id and class attributes"
	},
	"id": {
		"prefix": ["id"],
		"body": [
			"id=\"${1:id}\""
		],
		"description": "id attribute"
	},
	"class": {
		"prefix": ["class"],
		"body": [
			"class=\"${1:class}\""
		],
		"description": "class attribute"
	},
	"button": {
		"prefix": ["button"],
		"body": [
			"<button class=\"${1:button}\" type=\"${2:button}\" onclick=\"${3:OnClick}\">${4:$TM_SELECTED_TEXT}$0</button>"
		],
		"description": "button"
	},
	"input": {
		"prefix": ["input"],
		"body": [
			"<input type=\"text\" id=\"${1:id}\" name=\"${2:name}\" ${3:required} minlength=\"${4:minlength}\" maxlength=\"${5:maxlength}\" size=\"${6:size}\">",
			"<!- [More Info Here](https://developer.mozilla.org/en-US/docs/Web/HTML/Element/Input) -->"
		],
		"description": "input element"
	},
	"label": {
		"prefix": ["label"],
		"body": [
			"<label for=\"${1:ElementBeingLabeled}\">${2:$TM_SELECTED_TEXT}$0</label>"
		],
		"description": "label"
	},
	"address": {
		"prefix": ["address"],
		"body": [
			"<address>${1:$TM_SELECTED_TEXT}</address>"
		],
		"description": "address"
	},
	"article": {
		"prefix": ["article"],
		"body": [
			"<article>${1:$TM_SELECTED_TEXT}</article>"
		],
		"description": "article"
	},
	"span": {
		"prefix": ["span"],
		"body": [
			"<span>${1:$TM_SELECTED_TEXT}</span>"
		],
		"description": "span"
	},
	"table": {
		"prefix": ["table"],
		"body": [
			"<table>",
			"\t<caption>${1:TableCaption}</caption>",
			"\t<thead>",
			"\t\t<tr>",
			"\t\t\t<th colspan=\"${2:NumberOfCols}\">${3:The Table Header}</th>",
			"\t\t</tr>",
			"\t</thead>",
			"\t<tbody>",
			"\t\t<tr>",
			"\t\t\t${4:$TM_SELECTED_TEXT}",
			"\t\t</tr>",
			"\t</tbody>",
			"</table>"
		],
		"description": "table in html"
	},
	"table head": {
		"prefix": ["thead"],
		"body": [
			"<thead>",
			"\t<tr>",
			"\t\t<th scope=\"${1:row or col}\">${2:$TM_SELECTED_TEXT}</th>",
			"\t</tr>",
			"</thead>"
		],
		"description": "table head"
	},
	"table foot": {
		"prefix": ["tfoot"],
		"body": [
			"<tfoot>",
			"\t<tr>",
			"\t\t<th scope=\"row\">${1:FooterName}</th>",
			"\t\t<td>${2:$TM_SELECTED_TEXT}</td>",
			"\t</tr>",
			"</tfoot>"
		],
		"description": "table footer"
	},
	"table body": {
		"prefix": ["tbody"],
		"body": [
			"<tbody>",
			"\t<tr>",
			"\t\t<th scope=\"row\">${1:RowHeader}</th>",
			"\t\t<td>${2:$TM_SELECTED_TEXT}$0</td>",
			"\t</tr>",
			"</tbody>"
		],
		"description": "table body"
	},
	"table row": {
		"prefix": ["tr"],
		"body": [
			"<tr>${1:$TM_SELECTED_TEXT}</tr>"
		],
		"description": "table row"
	},
	"table cell": {
		"prefix": ["td"],
		"body": [
			"<td>${1:$TM_SELECTED_TEXT}</td>"
		],
		"description": "table cell"
	},
	"table row header cell": {
		"prefix": ["thr"],
		"body": [
			"<th scope=\"${1:row}\">${2:$TM_SELECTED_TEXT}$0</th>"
		],
		"description": "table row header cell"
	},
	"table column header cell": {
		"prefix": ["thc"],
		"body": [
			"<th scope=\"${1:col}\">${2:$TM_SELECTED_TEXT}$0</th>"
		],
		"description": "table column header cell"
	},
	"table header cell": {
		"prefix": ["th"],
		"body": [
			"<th scope=\"${1:row or col}\">${2:$TM_SELECTED_TEXT}$0</th>"
		],
		"description": "table header cell"
	},
	"comment": {
		"prefix": ["comment"],
		"body": [
			"<!-- ${1:$TM_SELECTED_TEXT}$0 -->"
		],
		"description": "comment"
	},
	"description list": {
		"prefix": ["dl", "descripiton-list", "definition-list"],
		"body": [
			"<dl>",
			"\t<dt>${1:term}</dt>",
			"\t<dd>${2:description or definition}</dd>",
			"\t$0",
			"</dl>"
		],
		"description": "Description List / Definition List\" t"
	},
	"definion": {
		"prefix": ["def", "description", "definition"],
		"body": [
			"<dt>${1:term}</dt>",
			"<dd>${2:description or definition}</dd>",
			"$0"
		],
		"description": "Description or Definition entry"
	}
}
