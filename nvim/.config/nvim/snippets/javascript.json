{
	"clog": {
		"prefix": ["clog"],
		"body": [
			"console.log(${1:$TM_SELECTED_TEXT});"
		],
		"description": "console.log"
	},

	"ctable": {
		"prefix": ["ctable"],
		"body": [
			"console.table(${1:$TM_SELECTED_TEXT});"
		],
		"description": "console.table"
	},

	"if": {
		"prefix": ["if"],
		"body": [
			"if (${1:condition}) {",
			"\t${2:statement}",
			"}"
		],
		"description": "if statement"
	},

	"else": {
		"prefix": ["else"],
		"body": [
			"else {",
			"\t${1:else statement}",
			"}"
		],
		"description": "else statement"
	},

	"elif": {
		"prefix": ["elif"],
		"body": [
			"else if (${1:condition}) {",
			"\t${2:statement}",
			"}"
		],
		"description": "else if statement"
	},

	"for": {
		"prefix": ["for"],
		"body": [
			"for (var ${1:i} = ${2:0}; ${1} ${3:<} ${4:10}; ${1}${5:++}) {",
			"\t$0",
			"}"
		],
		"description": "for loop"
	},

	"forin": {
		"prefix": ["forin"],
		"body": [
			"// var object1 = { a: 1, b: 2, c: 3 };",
			"",
			"for (var ${1:property} in ${2:object}) {",
			"\t$0",
			"}"
		],
		"description": "for...in loop"
	},

	"while": {
		"prefix": ["while"],
		"body": [
			"while (var ${1:i} ${2:<} ${3:9}) {",
			"\t${1}${4:++};",
			"}"
		],
		"description": "while loop"
	},

	"dowhile": {
		"prefix": ["dowhile"],
		"body": [
			"var ${1:i} = ${2:initializationValue};",
			"do {",
			"\t${1} ${3:+=} ${4:incrementValue};",
			"\t${5:output}",
			"} while (${1} ${6:<} ${7:comparisonValue})"
		],
		"description": "do while loop"
	},

	"class": {
		"prefix": ["class"],
		"body": [
			"class ${1:ClassName} {",
			"\tconstructor(${2:Constructor1}, ${3:Constructor2}) {",
			"\t\tthis.name = '${1}';",
			"\t\tthis.${2} = ${2};",
			"\t\tthis.${3} = ${3};",
			"\t}",
			"}"
		],
		"description": "class definition"
	},

	"func": {
		"prefix": ["func"],
		"body": [
			"function ${1:functionName}(${2:variables passed}) {",
			"\t${3:var let} ${4:returnVar} = ${5:returnVarValue};",
			"\t$0",
			"\treturn ${4};",
			"}"
		],
		"description": "function"
	},

	"funcv": {
		"prefix": ["funcv"],
		"body": [
			"${1:var let} ${2:name} = function ${3:functionName}(${4:variables passed}) {",
			"\t${5:var let} ${6:returnVar} = ${7:returnVarValue};",
			"\t$0",
			"\treturn ${6};",
			"};"
		],
		"description": "function expression"
	},

	"func>": {
		"prefix": ["func>"],
		"body": [
			"${1:var let} ${2:name} = (${3:variables passed}) => ${4:functionExpression a + b}"
		],
		"description": "arrow function"
	},

	"var": {
		"prefix": ["var"],
		"body": [
			"var ${1:name} = ${2:value};"
		],
		"description": "var declaration"
	},

	"let": {
		"prefix": ["let"],
		"body": [
			"let ${1:name} = ${2:value};"
		],
		"description": "let declaration"
	},

	"const": {
		"prefix": ["const"],
		"body": [
			"const ${1:NAME} = ${2:value};"
		],
		"description": "const declaration"
	},

	"bcom": {
		"prefix": ["bcom"],
		"body": [
			"/* ${1:$TM_SELECTED_TEXT} */"
		],
		"description": "block comment"
	},

	"switch": {
		"prefix": ["switch"],
		"body": [
			"switch (${1:variableName}) {",
			"\tcase ${2:case1}:",
			"\t\t${3:case1Actions}",
			"\t\tbreak;",
			"\tcase ${4:case2}:",
			"\t\t${5:case2Actions}",
			"\t\tbreak;",
			"\tdefault:",
			"\t\tbreak;",
			"}"
		],
		"description": "switch statement"
	},

	"keyval": {
		"prefix": ["keyval"],
		"body": [
			"${1:key}: \"${2:value}\""
		],
		"description": "object key/value"
	},

	"obj": {
		"prefix": ["obj"],
		"body": [
			"${1:let} ${2:objName} = { ${3:key}: \"${4:value}\" };"
		],
		"description": "object declaration"
	},

	"array": {
		"prefix": ["array"],
		"body": [
			"${1:let} ${2:arrayName} = [${3:element1}, ${4:element2}$0];"
		],
		"description": "array declaration"
	},

	"AND": {
		"prefix": ["AND"],
		"body": [
			"&& $0"
		],
		"description": "logical AND"
	},

	"OR": {
		"prefix": ["OR"],
		"body": [
			"|| $0"
		],
		"description": "logical OR"
	},

	"NOT": {
		"prefix": ["NOT"],
		"body": [
			"!$0"
		],
		"description": "logical NOT"
	},

	"trycatch": {
		"prefix": ["trycatch"],
		"body": [
			"try {",
			"\t${1:tryFunction}",
			"}",
			"catch(err) {",
			"\t${2:catchFunctionOrLog}",
			"\t${3:console.log(err)}",
			"}"
		],
		"description": "try/catch block"
	}
}
