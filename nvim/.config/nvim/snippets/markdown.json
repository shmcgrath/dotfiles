{
	"i": {
		"prefix": ["i"],
		"body": [
			"*${1:${TM_SELECTED_TEXT}}*$0"
		],
		"description": "Italics"
	},
	"b": {
		"prefix": ["b"],
		"body": [
			"**${1:${TM_SELECTED_TEXT}}**$0"
		],
		"description": "Bold"
	},
	"bi": {
		"prefix": ["bi"],
		"body": [
			"***${1:${TM_SELECTED_TEXT}}***$0"
		],
		"description": "Bold italics"
	},
	"h1": {
		"prefix": ["h1"],
		"body": [
			"# ${1:${TM_SELECTED_TEXT:Heading}}${3:[${2:unique_id}]}",
			"$0"
		],
		"description": "Heading 1"
	},
	"h2": {
		"prefix": ["h2"],
		"body": [
			"## ${1:${TM_SELECTED_TEXT:Heading}}${3:[${2:unique_id}]}",
			"$0"
		],
		"description": "Heading 2"
	},
	"h3": {
		"prefix": ["h3"],
		"body": [
			"### ${1:${TM_SELECTED_TEXT:Heading}}${3:[${2:unique_id}]}",
			"$0"
		],
		"description": "Heading 3"
	},
	"h4": {
		"prefix": ["h4"],
		"body": [
			"#### ${1:${TM_SELECTED_TEXT:Heading}}${3:[${2:unique_id}]}",
			"$0"
		],
		"description": "Heading 4"
	},
	"h5": {
		"prefix": ["h5"],
		"body": [
			"##### ${1:${TM_SELECTED_TEXT:Heading}}${3:[${2:unique_id}]}",
			"$0"
		],
		"description": "Heading 5"
	},
	"h6": {
		"prefix": ["h6"],
		"body": [
			"###### ${1:${TM_SELECTED_TEXT:Heading}}${3:[${2:unique_id}]}",
			"$0"
		],
		"description": "Heading 6"
	},
	"ref": {
		"prefix": ["ref"],
		"body": [
			"[${1:${TM_SELECTED_TEXT:Text}}][${2:SectionId}]$0"
		],
		"description": "Section reference"
	},
	"link": {
		"prefix": ["link"],
		"body": [
			"[${1:${TM_SELECTED_TEXT:Text}}](${2:${CLIPBOARD}})"
		],
		"description": "Markdown link"
	},
	"linkref": {
		"prefix": ["linkref"],
		"body": [
			"[${1:${TM_SELECTED_TEXT:Text}}][${2:id}]$0",
			"",
			"[${2:id}]: ${3:${CLIPBOARD}} \"${4:${3}}\""
		],
		"description": "Reference-style link"
    },
	"toc": {
		"prefix": ["toc"],
		"body": [
			"{{TOC:${1:2-3}}}"
		],
		"description": "Insert table of contents"
    },
	"code": {
		"prefix": ["code"],
		"body": [
			"```$1",
			"${TM_SELECTED_TEXT}",
			"```",
			"$0"
		],
		"description": "Code block"
	},
	"img": {
		"prefix": ["img"],
		"body": [
			"![${1:img alt}](${2:${CLIPBOARD}})"
		],
		"description": "Image"
	},
	"footnote": {
		"prefix": ["footnote"],
		"body": [
			"[^${1:footnote-id}]$0",
			"",
			"[^${1}]: ${2:${TM_SELECTED_TEXT:FootnoteText}}"
		],
		"description": "Footnote"
	},
	"footnote_inline": {
		"prefix": ["footnotei"],
		"body": [
			"[^${1:${TM_SELECTED_TEXT:Footnote}}]$0"
		],
		"description": "Inline footnote"
	},
	"note header": {
		"prefix": ["note-head"],
		"body": [
			"## ${CURRENT_YEAR}-${CURRENT_MONTH}-${CURRENT_DATE} ${CURRENT_HOUR}:${CURRENT_MINUTE} - ${1:${TM_SELECTED_TEXT:Heading}}",
			"$0"
		],
		"description": "Note header"
	}
}
