# Read `man 5 sway` for a complete reference of sway config options
exec_always kanshi
# TODO Make this a target
exec systemctl --user start dunst.service
exec systemctl --user restart wl-to-xclip
exec systemctl --user start sway-session.target

#NOT SURE IF NEEDED exec systemctl --user restart xdg-desktop-portal
# DO I NEED THIS STUFF??
#exec-once = systemctl --user start hyprpolkitagent
#exec = import-gtk-settings.sh

# Mod4 is logo key; use Mod1 for Alt
# QMK MEH is equal to control + shift + alt (right alt key)
# QMK HYPER is equal to control + shift + alt + super (right Windows key)
set $mainMod Mod4
set $hyperMod Mod4+Ctrl+Shift+Mod1

workspace_layout default

# Home row direction keys, like vim
set $left h
set $down j
set $up k
set $right l

# preferred programs
# terminal
set $term wezterm
# application launcher
set $menu fuzzel

### Output configuration
#
# Default wallpaper (more resolutions are available in /usr/share/backgrounds/sway/)
# TODO output * bg /usr/share/backgrounds/sway/Sway_Wallpaper_Blue_1920x1080.png fill
#exec-once = swaybg -m fill -i ~/.config/wallpaper/paris02.jpg
#
set $outputPrimary DP-3
set $outputSecondary HDMI-A-1

workspace 01 output $outputPrimary
workspace 02 output $outputPrimary
workspace 03 output $outputPrimary
workspace 04 output $outputPrimary
workspace 05 output $outputPrimary

workspace 06 output $outputSecondary
workspace 07 output $outputSecondary
workspace 08 output $outputSecondary
workspace 09 output $outputSecondary
workspace 10 output $outputSecondary

exec_always --no-startup-id swaymsg workspace 01

# Idle configuration handled by swayidle daemon
### Key bindings
#
# Basics:
#
# Kill focused window
bindsym $hyperMod+q kill

# Start a terminal
bindsym $mainMod+Return exec $term

# Start your launcher
bindsym $mainMod+space exec $menu

bindsym $hyperMod+Pause exec $HOME/.local/bin/menu-scripts/powermenu.sh
bindsym $hyperMod+f exec $HOME/.local/bin/menu-scripts/fuzzel-script-launcher.sh
bindsym Print exec grim -g "$(slurp)"
bindsym Shift+Print exec $HOME/.local/bin/menu-scripts/screenshot.sh
    # Drag floating windows by holding down $mainMod and left mouse button.
    # Resize them with right mouse button + $mainMod.
    # Despite the name, also works for non-floating windows.
    # Change normal to inverse to use left mouse button for resizing and right
    # mouse button for dragging.
    floating_modifier $mainMod normal

# Moving around:
    # Move your focus around
    bindsym $mainMod+$left focus left
    bindsym $mainMod+$down focus down
    bindsym $mainMod+$up focus up
    bindsym $mainMod+$right focus right
	bindsym $mainMod+n focus next
	bindsym $mainMod+p focus prev
bindsym $mainMod+mod1+n workspace next
bindsym $mainMod+mod1+p workspace prev

    # Move the focused window with the same, but add Shift
    bindsym $mainMod+Shift+$left move left
    bindsym $mainMod+Shift+$down move down
    bindsym $mainMod+Shift+$up move up
    bindsym $mainMod+Shift+$right move right

# Workspaces:
#
    # Switch to workspace
    bindsym $mainMod+1 workspace number 01
    bindsym $mainMod+2 workspace number 02
    bindsym $mainMod+3 workspace number 03
    bindsym $mainMod+4 workspace number 04
    bindsym $mainMod+5 workspace number 05
    bindsym $mainMod+6 workspace number 06
    bindsym $mainMod+7 workspace number 07
    bindsym $mainMod+8 workspace number 08
    bindsym $mainMod+9 workspace number 09
    bindsym $mainMod+0 workspace number 10
    # Move focused container to workspace
#bindsym $mainMod+Shift+1 [con_mark="scratchpad"] scratchpad show, move container to workspace number 01
#bindsym $mainMod+Shift+2 [con_mark="scratchpad"] move container to workspace number 02, scratchpad show; move container to workspace number 02
    bindsym $mainMod+Shift+1 move container to workspace number 01
    bindsym $mainMod+Shift+2 move container to workspace number 02
    bindsym $mainMod+Shift+3 move container to workspace number 03
    bindsym $mainMod+Shift+4 move container to workspace number 04
    bindsym $mainMod+Shift+5 move container to workspace number 05
    bindsym $mainMod+Shift+6 move container to workspace number 06
    bindsym $mainMod+Shift+7 move container to workspace number 07
    bindsym $mainMod+Shift+8 move container to workspace number 08
    bindsym $mainMod+Shift+9 move container to workspace number 09
    bindsym $mainMod+Shift+0 move container to workspace number 10
    # Note: workspaces can have any name you want, not just numbers.
    # We just use 1-10 as the default.
#
# Layout stuff:
#
    # You can "split" the current object of your focus with
    # $mainMod+b or $mainMod+v, for horizontal and vertical splits
    # respectively.
    bindsym $mainMod+v splith
    bindsym $mainMod+s splitv

    # Switch the current container between different layout styles
    bindsym $mainMod+w layout tabbed
    bindsym $mainMod+e layout toggle split

    # Make the current focus fullscreen
    bindsym $hyperMod+Home fullscreen

    # Toggle the current focus between tiling and floating mode
    bindsym $hyperMod+End floating toggle

    # Swap focus between the tiling area and the floating area
    bindsym $hyperMod+a focus mode_toggle

    # Move focus to the parent container
    bindsym $hyperMod+p focus parent
#
# Scratchpad:
#
    # Sway has a "scratchpad", which is a bag of holding for windows.
    # You can send windows there and get them back later.

    # Move the currently focused window to the scratchpad
    bindsym $mainMod+Shift+minus move scratchpad

    # Show the next scratchpad window or hide the focused scratchpad window.
    # If there are multiple scratchpad windows, this command cycles through them.
    bindsym $mainMod+minus scratchpad show
#
# Resizing containers:
#
mode "resize" {
    # left will shrink the containers width
    # right will grow the containers width
    # up will shrink the containers height
    # down will grow the containers height
    bindsym $left resize shrink width 10px
    bindsym $down resize grow height 10px
    bindsym $up resize shrink height 10px
    bindsym $right resize grow width 10px

    # Return to default mode
    bindsym Return mode "default"
    bindsym Escape mode "default"
}
bindsym $hyperMod+r mode "resize"

mode "media-control" {
	bindsym XF86AudioPrev exec playerctl previous
	bindsym XF86AudioPlay exec playerctl play-pause
	bindsym XF86AudioStop exec playerctl stop
	bindsym XF86AudioNext exec playerctl next
	bindsym XF86AudioRaiseVolume exec playerctl volume 0.05+
	bindsym XF86AudioForward exec playerctl position 10+
	bindsym XF86AudioRewind exec playerctl position 10-
	bindsym XF86AudioLowerVolume exec playerctl volume 0.05-
    # Return to default mode
    bindsym Return mode "default"
    bindsym Escape mode "default"
}
bindsym $hyperMod+m mode "media-control"

# Utilities:
bindsym ctrl+mod1+delete exec wezterm start --class "flying-htop" htop

# Special keys to adjust volume via PulseAudio
bindsym --locked XF86AudioMute exec pactl set-sink-mute \@DEFAULT_SINK@ toggle
bindsym --locked XF86AudioLowerVolume exec pactl set-sink-volume \@DEFAULT_SINK@ -5%
bindsym --locked XF86AudioRaiseVolume exec pactl set-sink-volume \@DEFAULT_SINK@ +5%
bindsym --locked XF86AudioMicMute exec pactl set-source-mute \@DEFAULT_SOURCE@ toggle
# Special keys to adjust brightness via brightnessctl
bindsym --locked XF86MonBrightnessDown exec brightnessctl set 5%-
bindsym --locked XF86MonBrightnessUp exec brightnessctl set 5%+

# Status Bar {{{
# for built-in bar man 5 sway-bar
bar {
    position top
	swaybar_command systemctl --user restart waybar@*;;
}

# Includes {{{2
# note what is in config.d
include /etc/sway/config.d/*
include ~/.config/sway/config.d/*

# Workspace Settings {{{2
workspace 04
workspace_layout tabbed
workspace 01
workspace_layout default
