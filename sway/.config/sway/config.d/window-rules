# Floating Windows
# flying- is for windows I may create myself
for_window [app_id="^flying-.*"] floating enable
for_window [window_role="pop-up"] floating enable
for_window [window_role="bubble"] floating enable
for_window [window_type="dialog"] floating enable
for_window [window_type="menu"] floating enable
for_window [window_role="dialog"] floating enable
for_window [window_role = "task_dialog"] floating enable

# File Explorer and Dialog
for_window [app_id="thunar" title="^Rename.*"] floating enable
for_window [title="(?:Open|Save) (?:File|Folder|As)"] floating enable, resize set width 1030 height 710
for_window [title="File Operation Progress"] floating enable, border pixel 1, sticky enable, resize set width 40 ppt height 30 ppt

# Firefox
for_window [app_id="firefox" title="Picture-in-Picture"] floating enable, resize set 400 400
for_window [app_id="firefox" title="Library$"] floating enable
for_window [app_id="firefox" title="^Enter name of file to save to.*"] floating enable, resize set width 1030 height 710
for_window [app_id="firefox" title = "Sharing Indicator$"] floating enable
for_window [app_id="firefox" title = ".*Kee - Mozilla Firefox"] floating enable
for_window [app_id="firefox" title = "(?i)Choose User Profile$" ] floating enable
for_window [app_id="^firefox.*" title="^About Mozilla Firefox$"] floating enable
for_window [app_id="^firefox.*" title="You’ve launched an older version of Firefox"] floating enable
#for_window [app_id="^firefox.*" title="^Page Info -.*"]                              focus, floating enable

# Misc
for_window [app_id="org.pulseaudio.pavucontrol" title="Volume Control"] floating enable
for_window [app_id="Gtk2fontsel"] floating enable
for_window [app_id="gpick"] floating enable, resize set width 1030 height 710
for_window [app_id="lxqt-policykit-agent"] focus, floating enable
for_window [app_id="^qt[5-6]ct$"]                                                    focus, floating enable
for_window [app_id="qalculate-gtk"], floating enable

# Application Default Workspaces
for_window [app_id="org.keepassxc.KeePassXC" title="(?i)KeePassXC$"] move to workspace 10
for_window [class="discord" title="Discord$"] move to workspace 09


# https://github.com/ValveSoftware/steam-for-linux/issues/1040
for_window [class="(?i)^steam$" title="^Friends$"] floating enable
for_window [class="(?i)^steam$" title="Steam - News"] floating enable
for_window [class="(?i)^steam$" title=".* - Chat"] floating enable
for_window [class="(?i)^steam$" title="^Settings$"] floating enable
for_window [class="(?i)^steam$" title=".* - event started"] floating enable
for_window [class="(?i)^steam$" title=".* CD key"] floating enable
for_window [class="(?i)^steam$" title="^Steam - Self Updater$"] floating enable
for_window [class="(?i)^steam$" title="^Screenshot Uploader$"] floating enable
for_window [class="(?i)^steam$" title="^Steam Guard - Computer Authorization Required$"] floating enable
for_window [title="^Steam Keyboard$"] floating enable
for_window [class="(?i)^steam$" title="Sign in to Steam"] move to workspace 04, floating enable
for_window [class="(?i)^steam$" title="Steam"] move to workspace 04

# Game Launchers and Support - 04
for_window [title="Battle.net"] move to workspace 04, fullscreen enable
for_window [app_id="net.lutris.Lutris" title="Lutris"] move to workspace 04
for_window [class="tsmapplication.exe" title="^TradeSkillMaster Application.*"] move to workspace 04
for_window [title="^TSMApplication.*"] floating enable

# Games - 05
for_window [title="World of Warcraft" class="steam_app_default"] move to workspace 05, fullscreen enable
for_window [class="steam_app_default"] move to workspace 05, fullscreen enable

