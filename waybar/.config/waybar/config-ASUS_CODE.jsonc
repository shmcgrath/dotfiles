		},
		"persistent-workspaces": {
			"06": [],
			"07": [],
			"08": [],
			"09": [],
			"10": [],
		}
	},
	"sway/window": {
		"format": "{title}",
		"max-length": 55,
		"all-outputs" : false,
		"offscreen-css" : true,
		"offscreen-css-text": "(inactive)",
		"rewrite": {
