{
    "layer": "top",
    "height": 30,
    "spacing": 4,
	"output": ["HDMI-A-1"],
    "modules-left": ["sway/scratchpad", "sway/workspaces", "sway/window"],
    "modules-center": [],
    "modules-right": [],
	"sway/workspaces": {
		"disable-scroll": true,
		"all-outputs": false,
		"format": "{name}: {icon}",
		"format-icons": {
			"urgent": "ïپھ",
			"focused": "ï†’",
			"default": "ï„‘",
