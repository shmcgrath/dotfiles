{
    "layer": "top", // Waybar at top layer
    "height": 30, // Waybar height (to be removed for auto height)
    "spacing": 4, // Gaps between modules (4px)
	"output": ["DP-3"],
    "modules-left": ["sway/scratchpad", "sway/workspaces", "sway/window", "sway/mode"],
    "modules-center": ["clock#shm", "clock#aus"],
    "modules-right": ["idle_inhibitor", "pulseaudio", "network", "systemd-failed-units", "cpu", "memory", "tray"],
    "idle_inhibitor": {
        "format": "{icon}",
        "format-icons": {
            "activated": "  ïپ®  ",
            "deactivated": "  ïپ°  "
        },
		"tooltip-format-activated": "Idle inhibitor activated.",
		"tooltip-format-deactivated": "Idle inhibitor deactivated."
    },
    "tray": {
		"icon-size": 21,
        "spacing": 10,
		"show-passive-items": true
    },
    "clock#shm": {
		"format": "َ°کک {:%a %d %b %I:%M %p}",
        "tooltip-format": "<big>{:%d %B %Y}</big>\n<tt><small>{calendar}</small></tt>",
		"calendar": {
			"mode": "year",
			"mode-mon-col": 3,
			"weeks-pos": "right",
			"on-scroll": 1,
			"format": {
			  "months": "<span color='#ffead3'><b>{}</b></span>",
			  "days": "<span color='#ecc6d9'><b>{}</b></span>",
			  "weeks": "<span color='#99ffdd'><b>W{}</b></span>",
			  "weekdays": "<span color='#ffcc66'><b>{}</b></span>",
			  "today": "<span color='#ff6699'><b><u>{}</u></b></span>"
			  }
		},
    },
    "clock#aus": {
		"format": "َ±•ک {:%a %d %b %I:%M %p (%Z)}",
		"tooltip-format": "{tz_list}",
		"timezones": [
			"Australia/Brisbane",
			"Etc/UTC",
			"Europe/London",
			"Europe/Paris",
			"Australia/Melbourne",
		]
		
    },
    "memory": {
        "format": "î؟… {}%"
    },
    "cpu": {
        "format": "ï‹› {usage}%",
        "tooltip": false
    },
    "network": {
		"format": "{ifname}",
        "format-wifi": "ï‡« {essid} ({signalStrength}%)",
        "format-ethernet": "î½„ {ipaddr}/{cidr}",
        "format-disconnected": "âڑ  No Network",
        "tooltip-format": "{ifname} via {gwaddr}",
		"tooltip-format-disconnected": "No network or network disconnected.",
        "format-alt": "{ifname}: {ipaddr}/{cidr}",
		"max-length": 50
    },
    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-muted": "َ°‌ں{icon}",
        "format-source": "ï„° {volume}%",
        "format-source-muted": "ï„± {volume}%",
        "format-bluetooth": "ïٹ”{icon} {volume}%",
		"tooltip-format": "{desc}\nInput: {format_source}",
        "format-icons": {
            "headphone": "ï€¥",
			"hdmi": "َ°،پ",
            "hands-free": "َ± °",
            "headset": "َ°‹ژ",
            "headset-muted": "َ°‹گ",
            "phone": "ï‚•",
			"phone-muted": "î´—",
            "portable": "ï‚•",
            "car": "ï†¹",
            "default": ["ï€§", "ï€¨"]
        },
        "on-click": "pavucontrol"
    },
	"custom/weather#AGC": {
		"format": "ïƒ© AGC {}",
		"exec": "curl \"wttr.in/AGC?format=%c%t+%h+%m%s&u\"",
		"interval": 900,
        "tooltip": false
	},
	"custom/weather#BNE": {
		"format": "ïƒ© BNE {}",
		"exec": "curl \"wttr.in/BNE?format=%c%t&u\"",
		"interval": 900,
        "tooltip": false
	},
	"systemd-failed-units": {
		"hide-on-ok": false,
		"format": "ï‹“ S: {nr_failed_system} U: {nr_failed_user}",
		"format-ok": "ï…ٹ",
		"system": true,
		"user": true
	},
	"load": {
		"interval": 10,
		"format": "ï‹› {load1}"
	},
	"sway/mode": {
		"format": "ïچ‌ {}",
		"max-length": 50
	},
	"sway/workspaces": {
		"disable-scroll": true,
		"all-outputs": false,
		"format": "{name}: {icon}",
		"format-icons": {
			"1": "ï„ ",
			"2": "ï‰¨",
			"3": "ï„،",
			"4": "ï†¼",
			"5": "ïپµ",
			"urgent": "ïپھ",
			"focused": "ï†’",
			"default": "ï„‘",
			"high-priority-named": ["1", "2"]
		},
		"persistent-workspaces": {
			"01": [],
			"02": [],
			"03": [],
			"04": [],
			"05": [],
		}
	},
	"sway/window": {
		"format": "{title}",
		"max-length": 500,
		"all-outputs" : false,
		"offscreen-css" : true,
		"offscreen-css-text": "(inactive)",
		"rewrite": {
			"(.*) â€” Mozilla Firefox$": "َ°ˆ¹ $1",
			"(.*) â€“ Mozilla Firefox$": "َ°ˆ¹ $1",
			"(.*) - Mozilla Firefox$": "َ°ˆ¹ $1",
			"(.*) - fish": "> [$1]"
		}
	}
}
